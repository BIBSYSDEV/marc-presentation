{
  "name": "marcpresentation-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "react-scripts build",
    "start": "react-scripts -r @cypress/instrument-cra start",
    "start:development": "env-cmd -f ./.env.development npm run-script start",
    "start:production": "env-cmd -f ./.env.production npm run-script start",
    "test": "cypress run",
    "test:cypress": "REACT_APP_USE_MOCK=true start-server-and-test http://localhost:3000"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "axios": "^1.18.0",
    "env-cmd": "^11.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-scripts": "5.0.1",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@cypress/code-coverage": "^3.14.5",
    "@cypress/instrument-cra": "^1.4.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^18.2.7",
    "axios-mock-adapter": "^1.21.5",
    "cypress": "^15.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^3.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "prettier": "^2.8.8",
    "pretty-quick": "^3.3.1",
    "start-server-and-test": "^3.0.11",
    "typescript": "~4.9.5"
  }
}
